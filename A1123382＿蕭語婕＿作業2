<?php
// 【關鍵 1：啟動會話】這必須放在檔案的最頂端，連一個空格都不能有
// 它的作用是讓伺服器記住這個使用者的狀態（例如：他已經登入過了）
session_start();

$error = ""; // 預設錯誤訊息為空

// 檢查是否為 POST 請求（代表使用者點擊了登入按鈕）
if ($_SERVER["REQUEST_METHOD"] == "POST") {
    // 接收表單傳來的帳號與密碼
    $user = $_POST['account'];
    $pass = $_POST['password'];

    // 【簡單驗證邏輯】這是練習用的寫法，直接把帳密寫死在程式裡
    if ($user === "admin" && $pass === "1234") {
        
        // 【關鍵 2：設定登入標記】
        // 將 Session 陣列中的 'loggedin' 設為 true
        // 這樣在其他頁面（如 0321.php）只要檢查這個變數，就知道使用者有沒有登入
        $_SESSION['loggedin'] = true;
        
        // 【關鍵 3：頁面跳轉】
        // header("Location: ...") 會叫瀏覽器直接飛往另一個頁面
        header("Location: 0321.php"); 
        
        // 跳轉後務必加上 exit，確保後面的程式碼不會被執行，節省資源也更安全
        exit;
        
    } else {
        // 如果帳密不符，將錯誤訊息存入變數，等一下顯示在畫面上
        $error = "帳號或密碼錯誤，請重新輸入！";
    }
}
?>

