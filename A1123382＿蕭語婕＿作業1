    /* --- PHP 處理區塊 --- */
    // 只有當使用者按了送出按鈕 (REQUEST_METHOD 為 POST) 才會執行
    if ($_SERVER["REQUEST_METHOD"] == "POST") {
        echo "<div class='result-box'>";
        echo "<h2>Submission Confirmed</h2>";

        // 【安全重點】使用 htmlspecialchars 避免 XSS 攻擊（把標籤轉成純文字）
        $name = htmlspecialchars($_POST['username']);
        $email = htmlspecialchars($_POST['email']);
        
        // 判斷日期是否有填寫，沒填就顯示「Not provided」
        $birthday = $_POST['birthday'] ? $_POST['birthday'] : "Not provided";
        
        // 使用 isset 檢查單選鈕是否被選中，避免沒選時報錯
        $gender = isset($_POST['gender']) ? $_POST['gender'] : "Not specified";
        $session = isset($_POST['session']) ? $_POST['session'] : "None";
        
        // 處理複選按鈕 (陣列)，利用 implode 將陣列轉為以逗號隔開的字串
        $interests = isset($_POST['interests']) ? implode(", ", $_POST['interests']) : "None";
        
        $tcolor = $_POST['tshirt_color'];
        
        // nl2br 會把使用者在文字區域按下的 Enter 轉成網頁的 <br> 換行標籤
        $comment = nl2br(htmlspecialchars($_POST['comment']));

        /* 定義一個 PHP 函式來重複生成顯示結果的表格列，減少重複代碼 */
        function showRow($label, $value) {
            echo "<div class='result-item'>
                    <span class='result-label'>$label</span>
                    <span class='result-value'>$value</span>
                  </div>";
        }

        // 呼叫函式將資料印在畫面上
        showRow("Name", $name);
        showRow("Email", $email);
        showRow("Birthday", $birthday);
        showRow("Gender", $gender);
        showRow("Session", $session);
        showRow("Interests", $interests);
        // 顏色部分直接把色碼套進 CSS 的 color 屬性裡
        showRow("Shirt Color", "<span style='color:$tcolor; font-weight:bold;'>$tcolor</span>");
        showRow("Comments", $comment ? $comment : "None");

        echo "</div>";
    }
    ?>

