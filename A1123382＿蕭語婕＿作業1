    // 檢查是否有資料透過 POST 送出
    if ($_SERVER["REQUEST_METHOD"] == "POST") {
        echo "<div class='result-box'>";
        echo "<h2>✅ 報名資料確認</h2>";

        // 定義一個方便顯示的函數
        function printResult($label, $content, $isColor = false) {
            echo "<div class='result-item'>";
            echo "<span class='result-label'>$label</span>";
            if ($isColor) {
                echo "<span class='result-content' style='display:inline-block; width:20px; height:20px; background-color:$content; border-radius:50%; vertical-align:middle; border:1px solid #ccc;'></span> <span class='result-content'>$content</span>";
            } else {
                echo "<span class='result-content'>$content</span>";
            }
            echo "</div>";
        }

        // 取得並清理資料
        $name = htmlspecialchars($_POST['username']);
        $email = htmlspecialchars($_POST['email']);
        $birthday = $_POST['birthday'] ? $_POST['birthday'] : "未填寫";
        $gender = isset($_POST['gender']) ? $_POST['gender'] : "未填寫";
        $session = isset($_POST['session']) ? $_POST['session'] : "未選擇";
        // 處理多選題
        $interests_str = "未勾選";
        if (isset($_POST['interests'])) {
            $interests_str = implode("、", $_POST['interests']);
        }
        $tcolor = $_POST['tshirt_color'];
        $comment = nl2br(htmlspecialchars($_POST['comment']));
        $comment_display = $comment ? $comment : "無特別備註";

        // 顯示結果
        printResult("姓名", $name);
        printResult("電子信箱", $email);
        printResult("出生日期", $birthday);
        printResult("性別", $gender);
        printResult("選擇梯次", $session);
        printResult("感興趣課程", $interests_str);
        printResult("T-shirt 顏色", $tcolor, true);
        printResult("備註內容", "<br>" . $comment_display);
        
        // 偵錯資訊
        echo "<div class='debug-info'>";
        echo "<strong>(Debug) POST 原始資料：</strong><pre>";
        print_r($_POST);
        echo "</pre></div>";

        echo "</div>"; // end .result-box
    }
